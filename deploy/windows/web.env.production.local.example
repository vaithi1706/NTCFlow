# DKFlow — Web environment (Windows production)
# Copy to: apps\web\.env.production.local
#
# Set this to your PUBLIC URL. The browser uses this for both:
#   - tRPC calls (when nginx/IIS isn't fronting /api)
#   - Socket.IO WebSocket connection
#
# If IIS is fronting / and proxying /api/* and /socket.io/* to the API, you can
# leave NEXT_PUBLIC_API_URL unset (the browser will use relative URLs). The
# value below is the safe default — works either way.

NEXT_PUBLIC_API_URL=https://dkflow.example.com
