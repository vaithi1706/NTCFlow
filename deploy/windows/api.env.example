# DKFlow — API environment (Windows production)
# Copy to: apps\api\.env
# All values MUST be set before starting the dkflow-api service.

# ── App ─────────────────────────────────────────────────────────
NODE_ENV=production
APP_URL=https://dkflow.example.com
API_URL=https://dkflow.example.com
PORT=4000

# ── Database ────────────────────────────────────────────────────
# Use the password set in deploy/windows/01-setup-db.sql.
DATABASE_URL=postgresql://dkflow:CHANGE-ME-STRONG-PASSWORD@localhost:5432/dkflow

# ── Redis (Memurai on Windows) ──────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE-ME-RUN-THE-NODE-COMMAND-ABOVE
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=12

# ── SMTP (transactional email: invites, password reset, notifications) ──
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=CHANGE-ME
EMAIL_FROM="DKFlow <noreply@example.com>"

# ── File uploads ────────────────────────────────────────────────
# Windows-native path. The dkflow-api service account must have write access.
UPLOAD_DIR=C:\dkflow\uploads
MAX_FILE_SIZE=26214400

# ── Rate limiting ───────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ── CORS extras ─────────────────────────────────────────────────
# Comma-separated origins to add to the API's allowlist (on top of the
# built-in defaults). Set this to your public site URL so the browser's
# tRPC + Socket.IO calls aren't blocked. Example:
#   EXTRA_CORS_ORIGINS=https://ntcflow.example.com
EXTRA_CORS_ORIGINS=

# ── AI (NVIDIA NIM — powers chat, embeddings, insights, document AI, Teams summaries) ──
NVIDIA_API_KEY=nvapi-CHANGE-ME
