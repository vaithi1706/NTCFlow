<?xml version="1.0" encoding="UTF-8"?>
<!--
  DKFlow — IIS reverse proxy for the Windows Server deployment.

  Place this file at:  C:\inetpub\dkflow\web.config
  Bind the IIS site to that folder, port 80 (and 443 once cert is installed).

  Prerequisites (IIS Manager → Modules / Server features):
    - Web-Server (IIS role)
    - Web-WebSockets feature  (Install-WindowsFeature Web-WebSockets)
    - URL Rewrite 2.1         (https://www.iis.net/downloads/microsoft/url-rewrite)
    - Application Request Routing 3.0  (https://www.iis.net/downloads/microsoft/application-request-routing)
    - In IIS Manager → server → "Application Request Routing Cache" →
      "Server Proxy Settings" → check "Enable proxy" → Apply.

  Routing:
    /api/*       → http://localhost:4000  (dkflow-api service)
    /socket.io/* → http://localhost:4000  (Socket.IO; needs WebSocket upgrade)
    /*           → http://localhost:3000  (dkflow-web Next.js)

  All three rules preserve query strings and forward client IP via X-Forwarded-For.
  WebSocket support is on by default in IIS once the Web-WebSockets feature is
  installed and ARR is configured.
-->
<configuration>
  <system.webServer>

    <!-- Allow streaming responses & long-running AI calls (default IIS timeout is 30s). -->
    <serverRuntime uploadReadAheadSize="0" />

    <rewrite>
      <rules>
        <!-- 1) Socket.IO — WebSocket-aware proxy to the API. -->
        <rule name="ProxySocketIO" stopProcessing="true">
          <match url="^socket\.io/(.*)" />
          <action type="Rewrite" url="http://localhost:4000/socket.io/{R:1}" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_FOR" value="{REMOTE_ADDR}" />
            <set name="HTTP_X_FORWARDED_PROTO" value="{HTTPS_OR_HTTP}" />
          </serverVariables>
        </rule>

        <!-- 2) /api/* — proxy to API service on :4000. -->
        <rule name="ProxyApi" stopProcessing="true">
          <match url="^api/(.*)" />
          <action type="Rewrite" url="http://localhost:4000/api/{R:1}" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_FOR" value="{REMOTE_ADDR}" />
            <set name="HTTP_X_FORWARDED_PROTO" value="{HTTPS_OR_HTTP}" />
          </serverVariables>
        </rule>

        <!-- 3) Everything else — Next.js web service on :3000. -->
        <rule name="ProxyWeb" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://localhost:3000/{R:1}" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_FOR" value="{REMOTE_ADDR}" />
            <set name="HTTP_X_FORWARDED_PROTO" value="{HTTPS_OR_HTTP}" />
          </serverVariables>
        </rule>
      </rules>

      <!-- Helper to set X-Forwarded-Proto correctly under HTTPS. -->
      <rewriteMaps>
        <rewriteMap name="HTTPS_OR_HTTP">
          <add key="on" value="https" />
          <add key="off" value="http" />
        </rewriteMap>
      </rewriteMaps>
    </rewrite>

    <!-- WebSocket protocol is enabled site-wide (needs Web-WebSockets feature). -->
    <webSocket enabled="true" />

    <!-- Don't add IIS's static-file handler — everything is proxied. -->
    <handlers accessPolicy="Read, Execute, Script" />

    <!-- Bigger upload ceiling (matches MAX_FILE_SIZE=25MB; bump if needed). -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="52428800" />
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
