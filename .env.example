# App
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dkflow

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=12

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@dkflow.com
SMTP_PASS=change-me
EMAIL_FROM="DKFlow <noreply@dkflow.com>"

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=26214400

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# CORS — extra allowed origins (comma-separated), appended to the built-in
# defaults (dkflow.in / localhost:3000). Set for each deployment that runs
# on a non-default URL. Example for a Lightsail-style IP+port deploy:
#   EXTRA_CORS_ORIGINS=http://3.221.48.192:3100,http://3.221.48.192:4100
EXTRA_CORS_ORIGINS=
